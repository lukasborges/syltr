<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.syltr.Syltr</id>

  <name>Syltr</name>
  <summary>Agregador de serviços de mensagens</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="dev.syltr">
    <name>Lucas Borges</name>
  </developer>

  <url type="homepage">https://github.com/lucasborges/syltr</url>
  <url type="bugtracker">https://github.com/lucasborges/syltr/issues</url>

  <description>
    <p>
      Syltr reúne vários serviços web de mensagens (WhatsApp Web, Telegram,
      Slack, Discord, Messenger e outros) numa única janela, no estilo do
      Franz — cada serviço com sua própria sessão isolada.
    </p>
    <p>Construído nativamente para o GNOME com GTK4, libadwaita e WebKitGTK.</p>
  </description>

  <launchable type="desktop-id">dev.syltr.Syltr.desktop</launchable>

  <categories>
    <category>Network</category>
    <category>InstantMessaging</category>
  </categories>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="0.1.0" date="2026-07-07">
      <description>
        <p>Primeira versão: sidebar de serviços, adicionar/remover, sessões
        isoladas por serviço e notificações.</p>
      </description>
    </release>
  </releases>
</component>
