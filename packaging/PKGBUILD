# Maintainer: Lucas Borges <lucas.borges@local>
#
# Syltr — agregador de serviços de mensagens com engine
# WebKitGTK 6 + GTK4/libadwaita.
#
# A engine é a webkitgtk-6.0 do sistema (pacote oficial do Arch): nada de
# download de binário de engine no build. Mídia (H.264/AAC, vídeo do WhatsApp)
# sai via GStreamer com os codecs do sistema — instale gst-libav.

pkgname=syltr
pkgver=0.1.0
pkgrel=12
pkgdesc="Agregador de serviços de mensagens — WebKitGTK 6 + GTK4"
arch=('x86_64')
url="https://github.com/lucasborges/syltr"
license=('GPL-3.0-or-later')
depends=(
  'gtk4' 'libadwaita' 'webkitgtk-6.0'
  'gst-plugins-base' 'gst-plugins-good'
  'hicolor-icon-theme'
)
optdepends=(
  'gst-libav: codecs H.264/AAC (vídeo do WhatsApp)'
  'hunspell-pt-br: verificação ortográfica em português'
)
makedepends=('rust' 'cargo' 'git' 'gettext' 'glib2')
options=('strip' '!debug' '!lto')
source=("$pkgname::git+file:///home/lucasborges/Projects/Syltr#branch=cef-spike")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname"
  export CARGO_TARGET_DIR="$srcdir/target"
  cargo build --release
  # Compila as traduções.
  for po in po/*.po; do
    msgfmt "$po" -o "${po%.po}.mo"
  done
}

package() {
  cd "$srcdir/$pkgname"

  install -Dm755 "$srcdir/target/release/syltr" "$pkgdir/usr/bin/syltr"

  # .desktop, ícone e metainfo.
  install -Dm644 data/dev.syltr.Syltr.desktop \
    "$pkgdir/usr/share/applications/dev.syltr.Syltr.desktop"
  install -Dm644 data/icons/dev.syltr.Syltr.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/dev.syltr.Syltr.svg"
  install -Dm644 data/dev.syltr.Syltr.metainfo.xml \
    "$pkgdir/usr/share/metainfo/dev.syltr.Syltr.metainfo.xml"

  # Traduções em /usr/share/locale (o app faz bindtextdomain aí).
  for mo in po/*.mo; do
    local lang
    lang=$(basename "$mo" .mo)
    install -Dm644 "$mo" "$pkgdir/usr/share/locale/$lang/LC_MESSAGES/syltr.mo"
  done
}
