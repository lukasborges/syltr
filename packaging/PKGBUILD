# Maintainer: Lucas Borges <lucas.borges@local>
#
# Syltr — messaging-service aggregator built on a WebKitGTK 6 +
# GTK4/libadwaita engine.
#
# The engine is the system's webkitgtk-6.0 (official Arch package): no engine
# binary is downloaded at build time. Media (H.264/AAC, WhatsApp video) plays
# through GStreamer using the system codecs — install gst-libav.

pkgname=syltr
pkgver=0.1.0
pkgrel=37
pkgdesc="Messaging-service aggregator — WebKitGTK 6 + GTK4"
arch=('x86_64')
url="https://github.com/lukasborges/syltr"
license=('GPL-3.0-or-later')
depends=(
  'gtk4' 'libadwaita' 'webkitgtk-6.0'
  'gst-plugins-base' 'gst-plugins-good'
  'gst-plugin-pipewire' 'gst-plugins-bad' 'libnice'
  'hicolor-icon-theme'
)
optdepends=(
  'gst-libav: codecs H.264/AAC (vídeo do WhatsApp)'
  'hunspell-pt-br: verificação ortográfica em português'
)
makedepends=('rust' 'cargo' 'git' 'gettext' 'glib2')
options=('strip' '!debug' '!lto')
source=("$pkgname::git+https://github.com/lukasborges/syltr.git#branch=main")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname"
  export CARGO_TARGET_DIR="$srcdir/target"
  cargo build --release
  # Compile the translations.
  for po in po/*.po; do
    msgfmt "$po" -o "${po%.po}.mo"
  done
}

package() {
  cd "$srcdir/$pkgname"

  install -Dm755 "$srcdir/target/release/syltr" "$pkgdir/usr/bin/syltr"

  # .desktop entry, icon and metainfo.
  install -Dm644 data/dev.syltr.Syltr.desktop \
    "$pkgdir/usr/share/applications/dev.syltr.Syltr.desktop"
  install -Dm644 data/icons/dev.syltr.Syltr.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/dev.syltr.Syltr.svg"
  install -Dm644 data/dev.syltr.Syltr.metainfo.xml \
    "$pkgdir/usr/share/metainfo/dev.syltr.Syltr.metainfo.xml"

  # Translations under /usr/share/locale (the app calls bindtextdomain there).
  for mo in po/*.mo; do
    local lang
    lang=$(basename "$mo" .mo)
    install -Dm644 "$mo" "$pkgdir/usr/share/locale/$lang/LC_MESSAGES/syltr.mo"
  done
}
